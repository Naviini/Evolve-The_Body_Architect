# ── Supabase (required) ─────────────────────────────────────────
# Go to: Supabase Dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Food Catalog Seeder (developer-only, never ship to app) ─────
# Only needed when running: npm run seed:foods
#
# Service-role key (bypasses RLS) — Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Free USDA FoodData Central API key
# Sign up at: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your_usda_api_key_here
